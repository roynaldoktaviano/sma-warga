generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  KESISWAAN
  BKA
}

enum Jenis {
  PELANGGARAN
  PRESTASI
}

enum StatusAbsen {
  IZIN
  SAKIT
  ALPA
}

enum Tingkat {
  SEKOLAH
  KOTA
  PROVINSI
  NASIONAL
  INTERNASIONAL
}

model Sekolah {
  id        String   @id @default(cuid())
  nama      String
  staff     Staff[]
  siswa     Siswa[]
  createdAt DateTime @default(now())
}

model Staff {
  id        String      @id @default(cuid())
  nama      String
  username  String      @unique
  password  String
  role      Role
  sekolah   Sekolah     @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  sekolahId String
  catatan   Catatan[]
  presensi  Presensi[]
  prestasi  Prestasi[]
  createdAt DateTime    @default(now())

  @@index([sekolahId])
}

model Siswa {
  id           String     @id @default(cuid())
  nama         String
  kelas        String
  nis          String     @unique
  nisn         String?    @unique
  jenisKelamin String     @default("L")   // L atau P
  agama        String     @default("")
  asalSD       String?
  statusDL     String?                    // D = Dalam kota, L = Luar kota
  status       String     @default("AKTIF") // AKTIF | LULUS | PINDAH
  username     String     @unique
  password     String
  poinAwal     Int        @default(100)
  sekolah      Sekolah    @relation(fields: [sekolahId], references: [id], onDelete: Cascade)
  sekolahId    String
  catatan      Catatan[]
  presensi     Presensi[]
  prestasi     Prestasi[]
  createdAt    DateTime   @default(now())

  @@index([sekolahId])
  @@index([status])
}

model Catatan {
  id           String   @id @default(cuid())
  siswa        Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  siswaId      String
  jenis        Jenis
  kategori     String
  poin         Int
  keterangan   String?
  tanggal      DateTime @db.Date
  pencatat     Staff?   @relation(fields: [pencatatId], references: [id], onDelete: SetNull)
  pencatatId   String?
  pencatatNama String
  createdAt    DateTime @default(now())

  @@index([siswaId])
  @@index([tanggal])
}

model Presensi {
  id           String      @id @default(cuid())
  siswa        Siswa       @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  siswaId      String
  tanggal      DateTime    @db.Date
  status       StatusAbsen
  keterangan   String?
  pencatat     Staff?      @relation(fields: [pencatatId], references: [id], onDelete: SetNull)
  pencatatId   String?
  pencatatNama String
  createdAt    DateTime    @default(now())

  @@unique([siswaId, tanggal])
  @@index([siswaId])
  @@index([tanggal])
}

model Prestasi {
  id           String   @id @default(cuid())
  siswa        Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  siswaId      String
  judul        String
  kategori     String
  tingkat      Tingkat
  peringkat    String?
  tanggal      DateTime @db.Date
  keterangan   String?
  pencatat     Staff?   @relation(fields: [pencatatId], references: [id], onDelete: SetNull)
  pencatatId   String?
  pencatatNama String
  createdAt    DateTime @default(now())

  @@index([siswaId])
  @@index([tanggal])
}
